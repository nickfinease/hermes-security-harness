{
  "schemaVersion": "auth-scan/v1",
  "description": "Schema for authentication flow scan results.",
  "properties": {
    "schemaVersion": { "type": "string" },
    "runId": { "type": "string" },
    "targetId": { "type": "string" },
    "generatedAt": { "type": "string" },
    "summary": {
      "type": "object",
      "properties": {
        "totalTests": { "type": "integer" },
        "cookieTests": { "type": "integer" },
        "bypassTests": { "type": "integer" },
        "rateTests": { "type": "integer" }
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "finding/v1#/definitions/finding" }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["schemaVersion", "runId", "targetId", "findings"],
  "type": "object"
}
