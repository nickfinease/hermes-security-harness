{
  "schemaVersion": "static-agent-findings/v1",
  "description": "Structured findings from a static source scan agent (Hermi source-only review).",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Schema version string."
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "informational"] },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "affected": { "type": "object" },
          "description": { "type": "string" },
          "evidence": { "type": "object" },
          "remediation": { "type": "object" }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Scope limits, uncertainty, or why findings is empty."
    }
  },
  "required": ["schemaVersion", "findings", "notes"],
  "type": "object"
}
